# connector-test — canonical shared config for the full local connector flow.
# Sourced by every script here. One cred set + one port map + the resolved
# endpoints for the shared-net stack that hydradb-application/scripts/local-e2e
# brings up. See README.md for the port map and the flow diagram.
#
# NOTE: this file holds only NON-secret local dev values. Real connector tokens
# are entered through the Go API at test time (encrypted into DynamoDB via moto
# KMS) — never put a real token here.

# ---- repo checkouts (override CODE_DIR if your repos live elsewhere) --------
: "${CODE_DIR:=$HOME/code}"
export CODE_DIR
export MOVEIT_ROOT="$CODE_DIR/MOVEIT"
export HYDRA_ROOT="$CODE_DIR/hydradb-application"
export INGESTION_ROOT="$CODE_DIR/cortex-ingestion"
export CORTEX_APP_ROOT="$CODE_DIR/cortex-application"   # seed-only (not run)
export DASHBOARD_ROOT="$CODE_DIR/dashboard-2.0/next-app"

# ---- shared AWS creds + endpoints (shared-net stack) -----------------------
# MinIO requires minioadmin; DynamoDB-local (-sharedDb) and moto ignore creds,
# so ONE cred set works for MOVEIT's DynamoDB + S3 + KMS clients at once.
export AWS_REGION=us-east-1
export AWS_DEFAULT_REGION=us-east-1
export AWS_ACCESS_KEY_ID=minioadmin
export AWS_SECRET_ACCESS_KEY=minioadmin
export AWS_ALLOW_HTTP=true

export DDB_ENDPOINT=http://localhost:8082          # shared-dynamodb (-sharedDb)
export S3_ENDPOINT=http://localhost:9002           # shared-minio
export KMS_ENDPOINT=http://localhost:4566          # cortex-secrets (moto)
export TEMPORAL_ENDPOINT=http://localhost:7233     # guru-team-temporal
export TEMPORAL_HOST_PORT=localhost:7233

# ---- KMS (must match hydradb-application dynamokms.go) ----------------------
export KMS_ALIAS=alias/hydradb-local-connectors

# ---- golang connector tables (owned/written by hydradb-application) ---------
export OAUTH_CONNECTORS_TABLE=oauth_connectors_local
export OAUTH_CONNECTOR_RESOURCES_TABLE=oauth_connector_resources_local
export CONNECTOR_CREDENTIALS_TABLE=connector_credentials_local

# ---- MOVEIT's own tables + lake bucket -------------------------------------
export MOVEIT_CURSOR_TABLE=moveit_cursors
export MOVEIT_STATE_TABLE=moveit_state
export MOVEIT_LAKE_BUCKET=moveit-lake

# ---- cortex-ingestion tables (config.ini [local]) --------------------------
export INGESTION_INBOX_TABLE=ingestion_inbox_local
export USER_INDEXED_DATA_TABLE=user_indexed_data_status_local

# ---- port map (see README) -------------------------------------------------
export MOVEIT_PORT=8090            # MOVEIT server (Go owns 8080)
export GO_API_PORT=8080
export INGESTION_API_PORT=8000
export INGESTION_WORKER_PORT=8001
export DASHBOARD_PORT=3000

# ---- MOVEIT base URL the Go connectors-worker drives -----------------------
export MOVEIT_BASE_URL=http://localhost:${MOVEIT_PORT}

# ---- tmux session name -----------------------------------------------------
export CT_TMUX_SESSION=connector-test
